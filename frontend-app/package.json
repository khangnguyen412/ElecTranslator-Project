{
  "name": "electranslator",
  "private": true,
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:frontend": "vite build",
    "build": "pnpm build:electron && pnpm build:frontend",
    "dist": "pnpm build && electron-builder",
    "clean": "rimraf release dist",
    "dev": "concurrently \"vite\" \"npm run electron:dev\"",
    "electron:dev": "wait-on http://localhost:5173 && tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron . ",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.electranslator.app",
    "productName": "ElecTranslator",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "@reduxjs/toolkit": "^2.12.0",
    "@tomjs/electron-devtools-installer": "^4.0.1",
    "antd": "^6.4.0",
    "axios": "^1.16.1",
    "canvas": "^3.2.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-redux": "^9.3.0",
    "react-router-dom": "^6.30.3",
    "screenshot-desktop": "^1.15.4",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "rimraf": "^6.1.3",
    "sass-embedded": "^1.100.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}